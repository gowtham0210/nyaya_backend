PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
DB_HOST=srv830.hstgr.io
DB_PORT=3306
DB_USER=your_mysql_user
DB_PASSWORD=your_mysql_password
DB_NAME=your_database_name
DB_CONNECTION_LIMIT=10
DB_CONNECT_TIMEOUT=10000
JWT_ACCESS_SECRET=replace-with-a-secure-access-secret
JWT_REFRESH_SECRET=replace-with-a-secure-refresh-secret
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d
REFRESH_COOKIE_NAME=nyaya_refresh_token
REFRESH_COOKIE_SAME_SITE=strict
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_PATH=/api/v1/auth
ADMIN_EMAILS=admin@nyaya.local
ADMIN_SEED_FULL_NAME=Nyaya Admin
ADMIN_SEED_EMAIL=admin@nyaya.local
